{
  "manifest_version": 3,
  "name": "Graphics Saver",
  "version": "1.1.0",
  "description": "Сохраняйте изображения с любых сайтов, даже там, где правый клик заблокирован.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "contextMenus",
    "downloads",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Graphics Saver"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "graphics-saver@local",
      "strict_min_version": "121.0"
    }
  }
}
